<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_branch_daily_document">
        <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="o">
                <t t-set="company" t-value="user.company_id"/>
                <t t-set="jobs" t-value="o.env['repair.job'].search([
                    ('branch_id', '=', o.branch_id.id),
                    ('date_received', '>=', str(o.date) + ' 00:00:00'),
                    ('date_received', '&lt;=', str(o.date) + ' 23:59:59'),
                ], order='name')"/>
                <t t-set="payments" t-value="o.env['repair.payment'].search([
                    ('branch_id', '=', o.branch_id.id),
                    ('state', '=', 'confirmed'),
                    ('payment_date', '=', o.date),
                ], order='id asc')"/>
                <t t-set="expenses" t-value="o.env['repair.petty.cash'].search([
                    ('branch_id', '=', o.branch_id.id),
                    ('state', '=', 'posted'),
                    ('transaction_type', '=', 'expense'),
                    ('date', '>=', str(o.date) + ' 00:00:00'),
                    ('date', '&lt;=', str(o.date) + ' 23:59:59'),
                ], order='date asc')"/>
                <t t-set="stock_alerts" t-value="o.env['repair.stock.alert'].search([
                    ('branch_id', '=', o.branch_id.id),
                    ('state', 'in', ('active', 'acknowledged')),
                    ('alert_type', 'in', ('low_stock', 'critical', 'out_of_stock')),
                ], order='alert_type, product_id')"/>

                <div class="page">
                    <div style="border-bottom: 2px solid #1f2937; padding-bottom: 10px; margin-bottom: 12px;">
                        <table style="width: 100%;">
                            <tr>
                                <td style="width: 20%; vertical-align: top;">
                                    <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" alt="Logo" style="max-height: 70px; max-width: 120px;"/>
                                </td>
                                <td style="width: 55%; vertical-align: top;">
                                    <h2 style="margin: 0; color: #111827;">DAILY OPERATIONS REPORT</h2>
                                    <div style="font-size: 13px; color: #374151; margin-top: 3px;">
                                        <strong>Branch:</strong>
                                        <span t-esc="o.branch_id.name"/>
                                        <span t-if="o.branch_id.code">(<span t-esc="o.branch_id.code"/>)</span>
                                    </div>
                                    <div style="font-size: 12px; color: #4b5563;">
                                        <strong>Date:</strong> <span t-esc="o.date"/> (<span t-esc="o.date.strftime('%A')"/>)
                                    </div>
                                </td>
                                <td style="width: 25%; vertical-align: top; text-align: right; font-size: 11px; color: #4b5563;">
                                    <div><strong>Generated By:</strong> <span t-esc="user.name"/></div>
                                    <div><strong>Generated At:</strong> <span t-esc="time.strftime('%Y-%m-%d %H:%M:%S')"/></div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <h4 style="margin: 10px 0 6px 0; color: #111827;">1. Repair Summary</h4>
                    <table style="width: 100%; border-collapse: separate; border-spacing: 6px 0;">
                        <tr>
                            <td style="width: 25%; background: #dbeafe; border: 1px solid #93c5fd; border-radius: 6px; text-align: center; padding: 10px;">
                                <div style="font-size: 11px; color: #1e3a8a;">Jobs Received Today</div>
                                <div style="font-size: 20px; font-weight: 700; color: #1d4ed8;" t-esc="o.total_jobs_received"/>
                            </td>
                            <td style="width: 25%; background: #dcfce7; border: 1px solid #86efac; border-radius: 6px; text-align: center; padding: 10px;">
                                <div style="font-size: 11px; color: #166534;">Jobs Completed Today</div>
                                <div style="font-size: 20px; font-weight: 700; color: #15803d;" t-esc="o.total_jobs_completed"/>
                            </td>
                            <td style="width: 25%; background: #ffedd5; border: 1px solid #fdba74; border-radius: 6px; text-align: center; padding: 10px;">
                                <div style="font-size: 11px; color: #9a3412;">Jobs Pending</div>
                                <div style="font-size: 20px; font-weight: 700; color: #c2410c;" t-esc="o.total_jobs_pending"/>
                            </td>
                            <td style="width: 25%; background: #f3e8ff; border: 1px solid #d8b4fe; border-radius: 6px; text-align: center; padding: 10px;">
                                <div style="font-size: 11px; color: #6b21a8;">Jobs Collected</div>
                                <div style="font-size: 20px; font-weight: 700; color: #7e22ce;" t-esc="o.total_jobs_collected"/>
                            </td>
                        </tr>
                    </table>

                    <h4 style="margin: 14px 0 6px 0; color: #111827;">2. Financial Summary</h4>
                    <table style="width: 100%; border-collapse: collapse; font-size: 12px;">
                        <tbody>
                            <tr><td style="padding: 6px; border: 1px solid #d1d5db;">Total Invoiced Today</td><td style="padding: 6px; border: 1px solid #d1d5db; text-align: right;"><span t-esc="format_amount(o.total_invoiced, company.currency_id)"/></td></tr>
                            <tr><td style="padding: 6px; border: 1px solid #d1d5db;">Cash Collected</td><td style="padding: 6px; border: 1px solid #d1d5db; text-align: right;"><span t-esc="format_amount(o.total_cash_collected, company.currency_id)"/></td></tr>
                            <tr><td style="padding: 6px; border: 1px solid #d1d5db;">POS Collected</td><td style="padding: 6px; border: 1px solid #d1d5db; text-align: right;"><span t-esc="format_amount(o.total_pos_collected, company.currency_id)"/></td></tr>
                            <tr><td style="padding: 6px; border: 1px solid #d1d5db;">Bank Transfer Collected</td><td style="padding: 6px; border: 1px solid #d1d5db; text-align: right;"><span t-esc="format_amount(o.total_transfer_collected, company.currency_id)"/></td></tr>
                            <tr style="font-weight: 700;"><td style="padding: 6px; border: 1px solid #9ca3af; background: #f3f4f6;">Total Collected</td><td style="padding: 6px; border: 1px solid #9ca3af; text-align: right; background: #f3f4f6;"><span t-esc="format_amount(o.total_grand_collected, company.currency_id)"/></td></tr>
                            <tr><td style="padding: 6px; border: 1px solid #d1d5db;">Total Expenses</td><td style="padding: 6px; border: 1px solid #d1d5db; text-align: right;"><span t-esc="format_amount(o.total_expenses, company.currency_id)"/></td></tr>
                            <tr style="font-weight: 700;"><td style="padding: 6px; border: 1px solid #9ca3af;">Net Revenue</td><td style="padding: 6px; border: 1px solid #9ca3af; text-align: right;"><span t-att-style="'color: %s;' % ('#15803d' if o.net_revenue &gt;= 0 else '#b91c1c')" t-esc="format_amount(o.net_revenue, company.currency_id)"/></td></tr>
                            <tr><td style="padding: 6px; border: 1px solid #d1d5db;">Outstanding Balance</td><td style="padding: 6px; border: 1px solid #d1d5db; text-align: right; color: #b91c1c;"><span t-esc="format_amount(o.total_outstanding, company.currency_id)"/></td></tr>
                        </tbody>
                    </table>

                    <h4 style="margin: 14px 0 6px 0; color: #111827;">3. Jobs List</h4>
                    <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                        <thead>
                            <tr style="background: #f3f4f6;">
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Job No</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Customer</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Device</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Technician</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Status</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px; text-align: right;">Total</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px; text-align: right;">Paid</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px; text-align: right;">Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="jobs" t-as="j">
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="j.name"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="j.customer_id.name"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="('%s %s' % ((j.device_brand or ''), (j.device_model or ''))).strip()"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="j.technician_id.name or '-'"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="dict(j._fields['state'].selection).get(j.state, j.state)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(j.total_cost, company.currency_id)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(j.amount_paid, company.currency_id)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(j.balance_due, company.currency_id)"/></td>
                            </tr>
                            <tr t-if="not jobs">
                                <td colspan="8" style="border: 1px solid #e5e7eb; padding: 6px; text-align: center; color: #6b7280;">No jobs found for this day.</td>
                            </tr>
                        </tbody>
                    </table>

                    <h4 style="margin: 14px 0 6px 0; color: #111827;">4. Payments Received</h4>
                    <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                        <thead>
                            <tr style="background: #f3f4f6;">
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Ref</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Job</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Customer</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Method</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px; text-align: right;">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="payments" t-as="p">
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="p.name"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="p.job_id.name"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="p.customer_id.name"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="dict(p._fields['payment_method'].selection).get(p.payment_method, p.payment_method)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(p.amount, company.currency_id)"/></td>
                            </tr>
                            <tr t-if="not payments">
                                <td colspan="5" style="border: 1px solid #e5e7eb; padding: 6px; text-align: center; color: #6b7280;">No payments received.</td>
                            </tr>
                        </tbody>
                    </table>

                    <h4 style="margin: 14px 0 6px 0; color: #111827;">5. Expenses</h4>
                    <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                        <thead>
                            <tr style="background: #f3f4f6;">
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Ref</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Type</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Note</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px; text-align: right;">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="expenses" t-as="e">
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="e.name"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="dict(e._fields['transaction_type'].selection).get(e.transaction_type, e.transaction_type)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="e.reference or e.notes or '-'"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(e.amount, company.currency_id)"/></td>
                            </tr>
                            <tr t-if="not expenses">
                                <td colspan="4" style="border: 1px solid #e5e7eb; padding: 6px; text-align: center; color: #6b7280;">No expenses posted.</td>
                            </tr>
                        </tbody>
                    </table>

                    <h4 style="margin: 14px 0 6px 0; color: #111827;">6. Cash Reconciliation</h4>
                    <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                        <thead>
                            <tr style="background: #f3f4f6;">
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Opening Cash</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Cash In</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Cash Out</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Expected Closing</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Actual Closing</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Difference</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(o.opening_cash, company.currency_id)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(o.cash_in, company.currency_id)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(o.cash_out, company.currency_id)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(o.expected_closing_cash, company.currency_id)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="format_amount(o.actual_closing_cash, company.currency_id)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-att-style="'color: %s;' % ('#15803d' if abs(o.cash_difference) &lt; 0.0001 else '#b91c1c')" t-esc="format_amount(o.cash_difference, company.currency_id)"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <h4 style="margin: 14px 0 6px 0; color: #111827;">7. Stock Alerts</h4>
                    <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                        <thead>
                            <tr style="background: #f3f4f6;">
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Product</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px;">Alert Type</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px; text-align: right;">Current</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px; text-align: right;">Minimum</th>
                                <th style="border: 1px solid #d1d5db; padding: 5px; text-align: right;">Shortage</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="stock_alerts" t-as="a">
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="a.product_id.display_name"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px;"><span t-esc="dict(a._fields['alert_type'].selection).get(a.alert_type, a.alert_type)"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="a.current_stock"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="a.minimum_stock"/></td>
                                <td style="border: 1px solid #e5e7eb; padding: 5px; text-align: right;"><span t-esc="a.shortage_qty"/></td>
                            </tr>
                            <tr t-if="not stock_alerts">
                                <td colspan="5" style="border: 1px solid #e5e7eb; padding: 6px; text-align: center; color: #6b7280;">No stock alerts for this branch.</td>
                            </tr>
                        </tbody>
                    </table>

                    <div style="margin-top: 24px; font-size: 11px; color: #374151;">
                        <table style="width: 100%;">
                            <tr>
                                <td style="width: 45%;">
                                    <div style="margin-bottom: 28px; border-bottom: 1px solid #6b7280;"></div>
                                    <div><strong>Closed By</strong> Signature</div>
                                </td>
                                <td style="width: 10%;"/>
                                <td style="width: 45%;">
                                    <div style="margin-bottom: 28px; border-bottom: 1px solid #6b7280;"></div>
                                    <div><strong>Approved By</strong> Signature</div>
                                </td>
                            </tr>
                        </table>
                        <div style="margin-top: 8px; text-align: right; color: #6b7280;">
                            Printed: <span t-esc="time.strftime('%Y-%m-%d %H:%M:%S')"/>
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

    <record id="action_report_branch_daily" model="ir.actions.report">
        <field name="name">Branch Daily Operations Report</field>
        <field name="model">repair.branch.day.close</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">repair_branch.report_branch_daily_document</field>
        <field name="report_file">repair_branch.report_branch_daily_document</field>
        <field name="print_report_name">'Daily Report - %s' % (object.name or object.branch_id.name)</field>
        <field name="binding_model_id" ref="model_repair_branch_day_close"/>
        <field name="binding_type">report</field>
    </record>
</odoo>

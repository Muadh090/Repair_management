        <field name="groups" eval="[(4, ref('repair_branch.group_repair_branch_manager')),
                                      (4, ref('repair_branch.group_repair_senior_technician')),
                                      (4, ref('repair_branch.group_repair_technician')),
                                      (4, ref('repair_branch.group_repair_receptionist')),
                                      (4, ref('repair_branch.group_repair_accountant'))]"/>

    <record id="rule_repair_job_technician_only" model="ir.rule">
        <field name="name">Repair Job Technician Assigned Only</field>
        <field name="model_id" ref="repair_management.model_repair_job"/>
        <field name="domain_force">['|', ('technician_id.user_id', '=', user.id), ('technician_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('repair_branch.group_repair_technician'))]"/>
    </record>


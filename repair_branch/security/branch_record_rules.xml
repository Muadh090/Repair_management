<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1) Repair Job - Branch Rule (Branch Manager and below except HO/Admin) -->
    <record id="rule_repair_job_branch_isolation" model="ir.rule">
        <field name="name">Repair Job Branch Isolation</field>
        <field name="model_id" ref="repair_management.model_repair_job"/>
        <field name="domain_force">[('branch_id', '=', user.branch_id.id)]</field>
        <field name="groups" eval="[(4, ref('repair_branch.group_repair_branch_manager')),
                                      (4, ref('repair_branch.group_repair_senior_technician')),
                                      (4, ref('repair_branch.group_repair_receptionist')),
                                      (4, ref('repair_branch.group_repair_accountant'))]"/>
    </record>


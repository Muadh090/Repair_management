<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_repair_branch_staff_list" model="ir.ui.view">
        <field name="name">repair.branch.staff.list</field>
        <field name="model">repair.branch.staff</field>
        <field name="arch" type="xml">
            <list string="Branch Staff"
                  decoration-muted="not is_active"
                  decoration-success="performance_percent &gt;= 100"
                  decoration-warning="performance_percent &gt;= 70 and performance_percent &lt; 100"
                  decoration-danger="performance_percent &lt; 70">
                <field name="employee_id"/>
                <field name="branch_id"/>
                <field name="role"/>
                <field name="date_assigned"/>
                <field name="is_active"/>
                <field name="jobs_this_month"/>
                <field name="revenue_this_month"/>
                <field name="performance_percent"/>
            </list>
        </field>
    </record>

    <record id="view_repair_branch_staff_form" model="ir.ui.view">
        <field name="name">repair.branch.staff.form</field>
        <field name="model">repair.branch.staff</field>
        <field name="arch" type="xml">
            <form string="Branch Staff">
                <header>
                    <button name="action_grant_system_access" type="object" string="Grant System Access" class="btn-primary"/>
                    <button name="action_revoke_system_access" type="object" string="Revoke System Access" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="branch_id"/>
                            <field name="user_id"/>
                            <field name="role"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="date_assigned"/>
                            <field name="date_left"/>
                            <field name="performance_target"/>
                            <field name="jobs_this_month"/>
                            <field name="revenue_this_month"/>
                            <field name="performance_percent"/>
                        </group>
                    </group>
                    <separator string="Approval Limits"/>
                    <group>
                        <group>
                            <field name="can_approve_discount"/>
                            <field name="max_discount_percent"/>
                            <field name="can_approve_expense"/>
                            <field name="max_expense_amount"/>
                        </group>
                        <group>
                            <field name="can_transfer_stock"/>
                            <field name="can_close_day"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Staff notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_repair_branch_staff_search" model="ir.ui.view">
        <field name="name">repair.branch.staff.search</field>
        <field name="model">repair.branch.staff</field>
        <field name="arch" type="xml">
            <search string="Search Staff">
                <field name="employee_id"/>
                <field name="branch_id"/>
                <field name="role"/>
                <separator/>
                <filter name="filter_active" string="Active Staff" domain="[('is_active', '=', True)]"/>
                <filter name="filter_managers" string="Managers Only" domain="[('role', 'in', ('branch_manager', 'assistant_manager'))]"/>
                <filter name="filter_technicians" string="Technicians Only" domain="[('role', 'in', ('senior_technician', 'technician'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_branch" string="By Branch" context="{'group_by': 'branch_id'}"/>
                    <filter name="group_role" string="By Role" context="{'group_by': 'role'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_repair_branch_staff" model="ir.actions.act_window">
        <field name="name">Staff Management</field>
        <field name="res_model">repair.branch.staff</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_repair_branch_staff_search"/>
    </record>

    <record id="view_repair_branch_announcement_list" model="ir.ui.view">
        <field name="name">repair.branch.announcement.list</field>
        <field name="model">repair.branch.announcement</field>
        <field name="arch" type="xml">
            <list string="Announcements"
                  decoration-danger="priority == 'urgent'"
                  decoration-warning="priority == 'important'"
                  decoration-muted="is_expired">
                <field name="name"/>
                <field name="priority" widget="badge"
                       decoration-danger="priority == 'urgent'"
                       decoration-warning="priority == 'important'"
                       decoration-info="priority == 'normal'"/>
                <field name="from_branch_id"/>
                <field name="date_posted"/>
                <field name="expiry_date"/>
                <field name="acknowledgement_count"/>
            </list>
        </field>
    </record>

    <record id="view_repair_branch_announcement_form" model="ir.ui.view">
        <field name="name">repair.branch.announcement.form</field>
        <field name="model">repair.branch.announcement</field>
        <field name="arch" type="xml">
            <form string="Announcement">
                <header>
                    <button name="action_post" type="object" string="Post" class="btn-primary"/>
                    <button name="action_acknowledge" type="object" string="Acknowledge" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="priority"/>
                            <field name="from_branch_id"/>
                            <field name="to_branch_ids" widget="many2many_tags"/>
                            <field name="acknowledgement_required"/>
                        </group>
                        <group>
                            <field name="date_posted"/>
                            <field name="posted_by"/>
                            <field name="expiry_date"/>
                            <field name="is_expired"/>
                            <field name="acknowledgement_count"/>
                        </group>
                    </group>
                    <separator string="Message"/>
                    <field name="message" widget="html"/>
                    <separator string="Acknowledgements"/>
                    <field name="acknowledged_by_ids" widget="many2many_tags"/>
                    <separator string="Attachments"/>
                    <field name="attachment_ids" widget="many2many_binary"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_repair_branch_announcement_kanban" model="ir.ui.view">
        <field name="name">repair.branch.announcement.kanban</field>
        <field name="model">repair.branch.announcement</field>
        <field name="arch" type="xml">
            <kanban default_group_by="priority" class="o_kanban_small_column">
                <field name="name"/>
                <field name="priority"/>
                <field name="from_branch_id"/>
                <field name="date_posted"/>
                <field name="expiry_date"/>
                <field name="acknowledgement_count"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <strong><field name="name"/></strong>
                            <span t-if="record.priority.raw_value == 'urgent'" class="badge text-bg-danger">Urgent</span>
                            <span t-elif="record.priority.raw_value == 'important'" class="badge text-bg-warning">Important</span>
                            <span t-else="" class="badge text-bg-info">Normal</span>
                        </div>
                        <div class="text-muted small mt-1">
                            <field name="from_branch_id"/>
                        </div>
                        <div class="text-muted small">
                            Posted: <field name="date_posted"/>
                        </div>
                        <div class="mt-2">
                            Acknowledged: <field name="acknowledgement_count"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_repair_branch_announcements" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">repair.branch.announcement</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_branch_cash_reconciliation_wizard_form" model="ir.ui.view">
        <field name="name">repair.branch.cash.reconciliation.wizard.form</field>
        <field name="model">repair.branch.cash.reconciliation.wizard</field>
        <field name="arch" type="xml">
            <form string="Cash Reconciliation" create="0" edit="1">
                <sheet>
                    <group>
                        <group string="Header">
                            <field name="branch_id"/>
                            <field name="date"/>
                            <field name="period"/>
                            <field name="reconciled_by"/>
                        </group>
                        <group string="Variance Summary">
                            <field name="total_variance"
                                   readonly="1"
                                   decoration-danger="total_variance &lt; 0"
                                   decoration-warning="total_variance &gt; 0"
                                   class="oe_inline"/>
                            <field name="variance_reason"
                                   placeholder="Required if there is any variance..."
                                   invisible="total_variance == 0"/>
                        </group>
                    </group>

                    <separator string="System Totals"/>
                    <group>
                        <group>
                            <field name="system_cash_total" readonly="1"/>
                            <field name="system_pos_total" readonly="1"/>
                            <field name="system_transfer_total" readonly="1"/>
                        </group>
                        <group>
                            <field name="system_grand_total" readonly="1" class="oe_inline"/>
                            <field name="system_expenses_total" readonly="1"/>
                            <field name="system_net_total" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Physical Count"/>
                    <group>
                        <group>
                            <field name="physical_cash"/>
                            <field name="physical_pos"/>
                            <field name="physical_transfer"/>
                        </group>
                        <group>
                            <field name="physical_grand_total" readonly="1" class="oe_inline"/>
                        </group>
                    </group>

                    <separator string="Variance Breakdown"/>
                    <group>
                        <group>
                            <field name="cash_variance" readonly="1"
                                   decoration-danger="cash_variance &lt; 0"
                                   decoration-warning="cash_variance &gt; 0"/>
                            <field name="pos_variance" readonly="1"
                                   decoration-danger="pos_variance &lt; 0"
                                   decoration-warning="pos_variance &gt; 0"/>
                        </group>
                        <group>
                            <field name="transfer_variance" readonly="1"
                                   decoration-danger="transfer_variance &lt; 0"
                                   decoration-warning="transfer_variance &gt; 0"/>
                            <field name="total_variance" readonly="1"
                                   decoration-danger="total_variance &lt; 0"
                                   decoration-warning="total_variance &gt; 0"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_reconciliation"
                            string="Confirm Reconciliation"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_branch_cash_reconciliation_wizard" model="ir.actions.act_window">
        <field name="name">Cash Reconciliation</field>
        <field name="res_model">repair.branch.cash.reconciliation.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_branch_cash_reconciliation_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>

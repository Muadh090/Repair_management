<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!-- REPORT ACTION                                                    -->
    <!-- ================================================================ -->
    <record id="action_report_repair_stock" model="ir.actions.report">
        <field name="name">Stock Report</field>
        <field name="model">stock.warehouse</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">repair_inventory.report_repair_stock</field>
        <field name="report_file">repair_inventory.report_repair_stock</field>
        <field name="binding_model_id" ref="stock.model_stock_warehouse"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ================================================================ -->
    <!-- REPORT TEMPLATE                                                  -->
    <!-- ================================================================ -->
    <template id="report_repair_stock">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="warehouse">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 12px;">

                        <!-- ============================================ -->
                        <!-- HEADER                                       -->
                        <!-- ============================================ -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <img t-if="warehouse.company_id.logo"
                                     t-att-src="image_data_uri(warehouse.company_id.logo)"
                                     style="max-height: 80px;" alt="Logo"/>
                                <h4 t-field="warehouse.company_id.name" class="mt-2"/>
                            </div>
                            <div class="col-6 text-end">
                                <h2 style="color: #875A7B; font-weight: bold;">STOCK REPORT</h2>
                                <p class="mb-0">
                                    <strong>Warehouse:</strong>
                                    <span t-field="warehouse.name"/>
                                </p>
                                <p class="mb-0" t-if="warehouse.branch_id">
                                    <strong>Branch:</strong>
                                    <span t-field="warehouse.branch_id"/>
                                </p>
                                <p class="mb-0">
                                    <strong>Report Date:</strong>
                                    <span t-esc="datetime.datetime.now().strftime('%Y-%m-%d %H:%M')"/>
                                </p>
                                <p class="mb-0">
                                    <strong>Generated By:</strong>
                                    <span t-esc="env.user.name"/>
                                </p>
                            </div>
                        </div>

                        <hr style="border-top: 2px solid #875A7B;"/>

                        <!-- ============================================ -->
                        <!-- SUMMARY BOX                                  -->
                        <!-- ============================================ -->
                        <t t-set="repair_products"
                           t-value="env['product.template'].search([('is_repair_part', '=', True)])"/>
                        <t t-set="location" t-value="warehouse.lot_stock_id"/>
                        <t t-set="all_quants"
                           t-value="env['stock.quant'].search([('location_id', 'child_of', location.id), ('product_id.product_tmpl_id.is_repair_part', '=', True)])"/>

                        <t t-set="total_parts" t-value="len(repair_products)"/>
                        <t t-set="total_stock_value" t-value="sum(all_quants.mapped(lambda q: q.quantity * q.product_id.standard_price))"/>

                        <t t-set="low_stock_products" t-value="[]"/>
                        <t t-set="out_of_stock_products" t-value="[]"/>
                        <t t-set="critical_products" t-value="[]"/>

                        <t t-foreach="repair_products" t-as="rp">
                            <t t-set="rp_quants" t-value="all_quants.filtered(lambda q: q.product_id.product_tmpl_id.id == rp.id)"/>
                            <t t-set="rp_qty" t-value="sum(rp_quants.mapped('quantity'))"/>
                            <t t-if="rp_qty &lt;= 0">
                                <t t-set="out_of_stock_products" t-value="out_of_stock_products + [rp]"/>
                            </t>
                            <t t-elif="rp_qty &lt;= rp.minimum_stock_qty">
                                <t t-set="low_stock_products" t-value="low_stock_products + [rp]"/>
                            </t>
                            <t t-if="rp.is_critical_part and rp_qty &lt;= rp.minimum_stock_qty">
                                <t t-set="critical_products" t-value="critical_products + [rp]"/>
                            </t>
                        </t>

                        <div class="row mb-4">
                            <div class="col text-center p-2" style="background: #f0f0f0; border-right: 1px solid #ddd;">
                                <div style="font-size: 22px; font-weight: bold; color: #875A7B;">
                                    <t t-esc="total_parts"/>
                                </div>
                                <div class="text-muted small">Total Parts</div>
                            </div>
                            <div class="col text-center p-2" style="background: #f0f0f0; border-right: 1px solid #ddd;">
                                <div style="font-size: 22px; font-weight: bold; color: #875A7B;">
                                    <t t-esc="'%.2f' % total_stock_value"/>
                                </div>
                                <div class="text-muted small">Total Stock Value</div>
                            </div>
                            <div class="col text-center p-2" style="background: #fff3cd; border-right: 1px solid #ddd;">
                                <div style="font-size: 22px; font-weight: bold; color: #856404;">
                                    <t t-esc="len(low_stock_products)"/>
                                </div>
                                <div class="text-muted small">Low Stock</div>
                            </div>
                            <div class="col text-center p-2" style="background: #f8d7da; border-right: 1px solid #ddd;">
                                <div style="font-size: 22px; font-weight: bold; color: #721c24;">
                                    <t t-esc="len(out_of_stock_products)"/>
                                </div>
                                <div class="text-muted small">Out of Stock</div>
                            </div>
                            <div class="col text-center p-2" style="background: #f5c6cb;">
                                <div style="font-size: 22px; font-weight: bold; color: #721c24;">
                                    <t t-esc="len(critical_products)"/>
                                </div>
                                <div class="text-muted small">Critical</div>
                            </div>
                        </div>

                        <!-- ============================================ -->
                        <!-- MAIN STOCK TABLE                             -->
                        <!-- ============================================ -->
                        <h4 style="color: #875A7B;">Full Stock Summary</h4>

                        <t t-set="sorted_products"
                           t-value="repair_products.sorted(key=lambda p: (p.categ_id.name or '', p.name or ''))"/>
                        <t t-set="grand_total_value" t-value="0"/>

                        <table class="table table-sm table-bordered" style="font-size: 11px;">
                            <thead>
                                <tr style="background: #875A7B; color: white;">
                                    <th>Part Code</th>
                                    <th>Part Name</th>
                                    <th>Category</th>
                                    <th class="text-end">Current Stock</th>
                                    <th class="text-end">Min Stock</th>
                                    <th class="text-end">Reorder Qty</th>
                                    <th class="text-end">Unit Cost</th>
                                    <th class="text-end">Total Value</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="current_category" t-value="''"/>
                                <t t-set="category_value" t-value="0"/>

                                <t t-foreach="sorted_products" t-as="product">
                                    <t t-set="p_quants" t-value="all_quants.filtered(lambda q: q.product_id.product_tmpl_id.id == product.id)"/>
                                    <t t-set="p_qty" t-value="sum(p_quants.mapped('quantity'))"/>
                                    <t t-set="p_value" t-value="p_qty * product.standard_price"/>
                                    <t t-set="grand_total_value" t-value="grand_total_value + p_value"/>

                                    <!-- Category subtotal row -->
                                    <t t-if="(product.categ_id.name or 'Uncategorized') != current_category and current_category != ''">
                                        <tr style="background: #e9ecef; font-weight: bold;">
                                            <td colspan="7" class="text-end">
                                                Subtotal — <t t-esc="current_category"/>:
                                            </td>
                                            <td class="text-end">
                                                <t t-esc="'%.2f' % category_value"/>
                                            </td>
                                            <td/>
                                        </tr>
                                        <t t-set="category_value" t-value="0"/>
                                    </t>
                                    <t t-set="current_category" t-value="product.categ_id.name or 'Uncategorized'"/>
                                    <t t-set="category_value" t-value="category_value + p_value"/>

                                    <!-- Product row -->
                                    <tr>
                                        <td><t t-esc="product.part_code or '-'"/></td>
                                        <td><t t-esc="product.name"/></td>
                                        <td><t t-esc="product.categ_id.name or '-'"/></td>
                                        <td class="text-end"><t t-esc="'%.1f' % p_qty"/></td>
                                        <td class="text-end"><t t-esc="'%.1f' % product.minimum_stock_qty"/></td>
                                        <td class="text-end"><t t-esc="'%.1f' % product.reorder_qty"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % product.standard_price"/></td>
                                        <td class="text-end"><t t-esc="'%.2f' % p_value"/></td>
                                        <td class="text-center">
                                            <t t-if="p_qty &lt;= 0">
                                                <span class="badge" style="background: #842029; color: white;">Out of Stock</span>
                                            </t>
                                            <t t-elif="product.is_critical_part and p_qty &lt;= product.minimum_stock_qty">
                                                <span class="badge" style="background: #dc3545; color: white;">Critical</span>
                                            </t>
                                            <t t-elif="p_qty &lt;= product.minimum_stock_qty">
                                                <span class="badge" style="background: #fd7e14; color: white;">Low</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge" style="background: #198754; color: white;">OK</span>
                                            </t>
                                        </td>
                                    </tr>
                                </t>

                                <!-- Last category subtotal -->
                                <t t-if="current_category != ''">
                                    <tr style="background: #e9ecef; font-weight: bold;">
                                        <td colspan="7" class="text-end">
                                            Subtotal — <t t-esc="current_category"/>:
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'%.2f' % category_value"/>
                                        </td>
                                        <td/>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background: #875A7B; color: white; font-weight: bold;">
                                    <td colspan="7" class="text-end">GRAND TOTAL</td>
                                    <td class="text-end">
                                        <t t-esc="'%.2f' % grand_total_value"/>
                                    </td>
                                    <td/>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ============================================ -->
                        <!-- LOW STOCK / OUT OF STOCK SECTION             -->
                        <!-- ============================================ -->
                        <t t-set="alert_products" t-value="low_stock_products + out_of_stock_products"/>
                        <t t-if="alert_products">
                            <div style="page-break-before: auto; margin-top: 30px;">
                                <h4 style="color: #dc3545;">
                                    <i class="fa fa-exclamation-triangle"/> Items Requiring Attention
                                </h4>

                                <table class="table table-sm table-bordered" style="font-size: 11px;">
                                    <thead>
                                        <tr style="background: #dc3545; color: white;">
                                            <th>Part Code</th>
                                            <th>Part Name</th>
                                            <th>Category</th>
                                            <th class="text-end">Current Stock</th>
                                            <th class="text-end">Min Stock</th>
                                            <th class="text-end">Reorder Qty</th>
                                            <th class="text-center">Critical</th>
                                            <th class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="alert_products" t-as="ap">
                                            <t t-set="ap_quants" t-value="all_quants.filtered(lambda q: q.product_id.product_tmpl_id.id == ap.id)"/>
                                            <t t-set="ap_qty" t-value="sum(ap_quants.mapped('quantity'))"/>
                                            <tr t-att-style="'background: #f8d7da;' if ap.is_critical_part else ''">
                                                <td><t t-esc="ap.part_code or '-'"/></td>
                                                <td>
                                                    <strong t-if="ap.is_critical_part">
                                                        <t t-esc="ap.name"/>
                                                    </strong>
                                                    <t t-else="">
                                                        <t t-esc="ap.name"/>
                                                    </t>
                                                </td>
                                                <td><t t-esc="ap.categ_id.name or '-'"/></td>
                                                <td class="text-end"><t t-esc="'%.1f' % ap_qty"/></td>
                                                <td class="text-end"><t t-esc="'%.1f' % ap.minimum_stock_qty"/></td>
                                                <td class="text-end"><t t-esc="'%.1f' % ap.reorder_qty"/></td>
                                                <td class="text-center">
                                                    <t t-if="ap.is_critical_part">
                                                        <span class="badge" style="background: #dc3545; color: white;">YES</span>
                                                    </t>
                                                    <t t-else="">—</t>
                                                </td>
                                                <td class="text-center">
                                                    <t t-if="ap_qty &lt;= 0">
                                                        <span class="badge" style="background: #842029; color: white;">Out of Stock</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge" style="background: #fd7e14; color: white;">Low</span>
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>

                        <!-- ============================================ -->
                        <!-- FOOTER                                       -->
                        <!-- ============================================ -->
                        <div class="text-center text-muted mt-4" style="font-size: 10px;">
                            <p>
                                This report was generated on
                                <t t-esc="datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')"/>
                                by <t t-esc="env.user.name"/> —
                                <t t-esc="warehouse.company_id.name"/>
                            </p>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!-- REPAIR PARTS CATALOG — LIST VIEW                                 -->
    <!-- ================================================================ -->
    <record id="view_product_template_repair_parts_list" model="ir.ui.view">
        <field name="name">product.template.repair.parts.list</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="Repair Parts Catalog"
                  decoration-danger="days_of_stock &lt; 7 and days_of_stock &gt;= 0"
                  decoration-muted="not is_repair_part">
                <field name="part_code"/>
                <field name="name"/>
                <field name="part_category"/>
                <field name="compatible_devices"/>
                <field name="standard_price" widget="monetary"/>
                <field name="qty_available" string="On Hand"/>
                <field name="minimum_stock_qty"/>
                <field name="is_critical_part" widget="boolean_toggle"/>
                <field name="days_of_stock"
                       decoration-danger="days_of_stock &lt; 7"
                       decoration-warning="days_of_stock &gt;= 7 and days_of_stock &lt; 14"
                       decoration-success="days_of_stock &gt;= 14"/>
                <field name="average_repair_usage"/>
                <field name="is_repair_part" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- REPAIR PARTS CATALOG — FORM VIEW (INHERITED)                     -->
    <!-- ================================================================ -->
    <record id="view_product_template_repair_form_inherit" model="ir.ui.view">
        <field name="name">product.template.repair.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//page[last()]" position="after">
                <page string="Repair Info"
                      name="repair_info"
                      invisible="not is_repair_part">
                    <group>
                        <group string="Part Details">
                            <field name="is_repair_part"/>
                            <field name="part_code"/>
                            <field name="part_category"/>
                            <field name="is_critical_part"/>
                        </group>
                        <group string="Stock Settings">
                            <field name="minimum_stock_qty"/>
                            <field name="reorder_qty"/>
                            <field name="days_of_stock"/>
                            <field name="average_repair_usage"/>
                        </group>
                    </group>
                    <group>
                        <group string="Purchase Info">
                            <field name="last_purchase_price" widget="monetary"/>
                            <field name="last_purchase_date"/>
                            <field name="total_used_in_repairs"/>
                        </group>
                    </group>
                    <separator string="Compatible Devices"/>
                    <field name="compatible_devices"
                           placeholder="e.g. iPhone 14, Samsung S23, Huawei P50..."/>
                    <separator string="Preferred Suppliers"/>
                    <field name="supplier_ids_repair" widget="many2many_tags"/>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- REPAIR PARTS CATALOG — KANBAN VIEW                               -->
    <!-- ================================================================ -->
    <record id="view_product_template_repair_parts_kanban" model="ir.ui.view">
        <field name="name">product.template.repair.parts.kanban</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <kanban string="Repair Parts">
                <field name="name"/>
                <field name="part_category"/>
                <field name="qty_available"/>
                <field name="minimum_stock_qty"/>
                <field name="is_critical_part"/>
                <field name="standard_price"/>
                <field name="part_code"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <strong>
                                <field name="name"/>
                            </strong>
                            <span t-if="record.is_critical_part.raw_value"
                                  class="badge text-bg-danger">Critical</span>
                        </div>
                        <div class="text-muted small">
                            <field name="part_code"/> |
                            <field name="part_category"/>
                        </div>
                        <div class="mt-2 d-flex justify-content-between align-items-center">
                            <span class="fw-bold">
                                Stock: <field name="qty_available"/>
                            </span>
                            <span t-if="record.qty_available.raw_value &lt;= 0"
                                  class="badge text-bg-danger">Out of Stock</span>
                            <span t-elif="record.qty_available.raw_value &lt;= record.minimum_stock_qty.raw_value"
                                  class="badge text-bg-warning">Low Stock</span>
                            <span t-else=""
                                  class="badge text-bg-success">In Stock</span>
                        </div>
                        <div class="text-muted small mt-1">
                            Price: <field name="standard_price" widget="monetary"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- REPAIR PARTS CATALOG — SEARCH VIEW                               -->
    <!-- ================================================================ -->
    <record id="view_product_template_repair_parts_search" model="ir.ui.view">
        <field name="name">product.template.repair.parts.search</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <search string="Search Repair Parts">
                <field name="name" string="Product Name"/>
                <field name="part_code"/>
                <field name="part_category"/>
                <field name="compatible_devices"/>
                <separator/>
                <filter name="filter_repair_parts"
                        string="Repair Parts Only"
                        domain="[('is_repair_part', '=', True)]"/>
                <filter name="filter_critical"
                        string="Critical Parts"
                        domain="[('is_critical_part', '=', True)]"/>
                <filter name="filter_low_stock"
                        string="Low Stock"
                        domain="[('qty_available', '&lt;=', 'minimum_stock_qty'), ('qty_available', '&gt;', 0)]"/>
                <filter name="filter_out_of_stock"
                        string="Out of Stock"
                        domain="[('qty_available', '&lt;=', 0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_category"
                            string="Part Category"
                            context="{'group_by': 'part_category'}"/>
                    <filter name="group_categ_id"
                            string="Product Category"
                            context="{'group_by': 'categ_id'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_repair_deposit" model="ir.sequence">
            <field name="name">Repair Deposit Sequence</field>
            <field name="code">repair.deposit</field>
            <field name="prefix">DEP/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_repair_payment" model="ir.sequence">
            <field name="name">Repair Payment Sequence</field>
            <field name="code">repair.payment</field>
            <field name="prefix">PAY/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>

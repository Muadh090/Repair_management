<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!-- FORM VIEW                                                        -->
    <!-- ================================================================ -->
    <record id="view_repair_deposit_form" model="ir.ui.view">
        <field name="name">repair.deposit.form</field>
        <field name="model">repair.deposit</field>
        <field name="arch" type="xml">
            <form string="Repair Deposit">
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_refund"
                            string="Refund"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'confirmed'"
                            confirm="Are you sure you want to refund this deposit?"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Deposit Details">
                            <field name="job_id"
                                   readonly="state != 'draft'"/>
                            <field name="customer_id"/>
                            <field name="branch_id"/>
                        </group>
                        <group string="Amount &amp; Method">
                            <field name="amount"
                                   readonly="state != 'draft'"/>
                            <field name="payment_method"
                                   readonly="state != 'draft'"/>
                            <field name="payment_reference"
                                   readonly="state != 'draft'"/>
                            <field name="date"
                                   readonly="state != 'draft'"/>
                            <field name="journal_id"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="received_by"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"
                           placeholder="Deposit notes..."
                           readonly="state != 'draft'"/>
                    <group string="Accounting" invisible="not move_id">
                        <field name="move_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- LIST VIEW                                                        -->
    <!-- ================================================================ -->
    <record id="view_repair_deposit_list" model="ir.ui.view">
        <field name="name">repair.deposit.list</field>
        <field name="model">repair.deposit</field>
        <field name="arch" type="xml">
            <list string="Repair Deposits"
                  decoration-muted="state == 'refunded'"
                  decoration-success="state == 'confirmed'">
                <field name="name"/>
                <field name="job_id"/>
                <field name="customer_id"/>
                <field name="amount" sum="Total"/>
                <field name="payment_method"/>
                <field name="date"/>
                <field name="received_by" optional="show"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-danger="state == 'refunded'"/>
            </list>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- SEARCH VIEW                                                      -->
    <!-- ================================================================ -->
    <record id="view_repair_deposit_search" model="ir.ui.view">
        <field name="name">repair.deposit.search</field>
        <field name="model">repair.deposit</field>
        <field name="arch" type="xml">
            <search string="Search Deposits">
                <field name="name" string="Reference"/>
                <field name="customer_id" string="Customer"/>
                <field name="job_id" string="Repair Job"/>
                <field name="payment_method" string="Payment Method"/>

                <separator/>
                <filter name="filter_today"
                        string="Today"
                        domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month"
                        string="This Month"
                        domain="[('date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <filter name="filter_cash"
                        string="Cash Only"
                        domain="[('payment_method', '=', 'cash')]"/>
                <filter name="filter_bank"
                        string="Bank Transfer Only"
                        domain="[('payment_method', '=', 'bank_transfer')]"/>
                <separator/>
                <filter name="filter_draft"
                        string="Pending Confirmation"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed"
                        string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_refunded"
                        string="Refunded"
                        domain="[('state', '=', 'refunded')]"/>

                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_customer"
                            string="Customer"
                            context="{'group_by': 'customer_id'}"/>
                    <filter name="group_method"
                            string="Payment Method"
                            context="{'group_by': 'payment_method'}"/>
                    <filter name="group_state"
                            string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_date"
                            string="Date"
                            context="{'group_by': 'date:month'}"/>
                    <filter name="group_received_by"
                            string="Received By"
                            context="{'group_by': 'received_by'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
